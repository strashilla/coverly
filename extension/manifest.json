{
    "manifest_version": 3,
    "name": "Coverly",
    "version": "1.0.0",
    "description": "Coverly генерирует сопроводительные письма для вакансий с помощью AI за один клик. Открой вакансию на hh.ru или LinkedIn.",
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "Coverly - generate cover letter",
        "default_icon": {
            "16": "icons/content.png",
            "32": "icons/content.png",
            "48": "icons/content.png",
            "128": "icons/content.png"
        }
    },
    "icons": {
        "16": "icons/content.png",
        "32": "icons/content.png",
        "48": "icons/content.png",
        "128": "icons/content.png"
    },
    "permissions": ["activeTab", "storage", "scripting"],
    "host_permissions": ["https://*.vercel.app/*"],
    "background": {
        "service_worker": "background/background.js"
    },
    "content_scripts": [{
        "matches": [
            "*://hh.ru/*",
            "*://*.hh.ru/*",
            "*://*.headhunter.ru/*",
            "*://*.rabota.ru/*",
            "*://*.superjob.ru/*",
            "*://*.linkedin.com/*"
        ],
        "js": ["content/content.js"]
    }],
    "web_accessible_resources": [{
        "resources": ["lib/pdf.worker.min.js"],
        "matches": ["<all_urls>"]
    }]
}