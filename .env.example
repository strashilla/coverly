# Copy to .env for local runs, or set in Vercel: Project → Settings → Environment Variables.
# Never commit a real .env file.

# Groq (https://console.groq.com/keys) — used only by api/generate.js on the server.
GROQ_API_KEY=

# Extension: edit extension/config.js → globalThis.COVERLY_API_URL (your Vercel URL + /api/generate).
# Vercel: add GROQ_API_KEY in the dashboard; do not put it in the extension or in git.
# If the API is not on *.vercel.app, add your origin to extension/manifest.json → host_permissions.
